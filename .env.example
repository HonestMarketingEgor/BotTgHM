TELEGRAM_BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE
OPENAI_API_KEY=PASTE_OPENAI_API_KEY_HERE
# Optional OpenAI-compatible endpoint (proxy/gateway).
# Example: https://api.openai.com/v1
OPENAI_BASE_URL=

# Where to store collected messages + summaries
DB_PATH=./data/bot.db

# OpenAI model used for daily summaries and /ask answers
OPENAI_MODEL=gpt-4o-mini
# OpenAI model used for "Предложения от ИИ" button
OPENAI_MODEL_SUGGESTIONS=

# Daily summary: wall-clock time in DAILY_TIMEZONE (default Europe/Moscow = 19:00 MSK)
DAILY_HOUR=19
DAILY_MINUTE=0
DAILY_TIMEZONE=Europe/Moscow

# How much context to include in prompts
MAX_MESSAGES_FOR_ASK=25
MAX_CONTEXT_CHARS=6000
MAX_PROJECT_MEMORY_CHARS=1800
ENABLE_AUTO_RESPONSE_MODE=true
DEFAULT_MODE=assistant_mode
ENABLE_CHAT_ANALYSIS=true

# Link fetching
URL_FETCH_TIMEOUT_S=20
MAX_LINK_CHARS=30000
MAX_LINKS=3

# If set, limit which chats are analyzed (comma-separated chat ids).
# Leave empty to analyze all chats where the bot is present.
ALLOWED_CHAT_IDS=
